# ── Ace 2.0 — Railway env vars ────────────────────────────────────────────────
# Shared with the Telegram bot / portal (same values — same brain, same voice):
GOOGLE_TOKEN_JSON=        # existing token; scopes already cover calendar/gmail/tasks/drive
ANTHROPIC_API_KEY=        # Ace's brain
OPENWEATHER_API_KEY=      # Cleveland weather

# Ace 2.0 only:
ACE2_PASSWORD=            # portal access code. UNSET = auth fully disabled.
ACE2_TOKEN_SECRET=        # optional; falls back to ANTHROPIC_API_KEY

# Voice — MUST match the Telegram bot exactly or the two Aces sound different:
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=      # the identity. Same value in both services.
ELEVENLABS_MODEL_ID=      # default eleven_flash_v2_5 (~75ms, real-time)
ELEVENLABS_VOICE_SETTINGS= # optional JSON: {"stability":0.5,"style":0.3,...}
