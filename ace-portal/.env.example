# ── Ace Portal environment ────────────────────────────────────────────────────
# On Railway these are SHARED with the ace-bot service. Do NOT create new copies
# of the Google/Anthropic vars — reference the existing ones. Never commit real
# values; this file only documents the names.

# Shared with the Telegram bot (already set on Railway):
ANTHROPIC_API_KEY=          # Ace's brain
GOOGLE_TOKEN_JSON=          # Google OAuth token JSON (Calendar, Gmail, Tasks, Drive)
GOOGLE_CREDENTIALS_JSON=    # Google OAuth client credentials JSON

# New for the portal:
OPENWEATHER_API_KEY=        # free key from openweathermap.org (Cleveland weather)
PORTAL_PASSWORD=            # single-user access code; leave BLANK to run open (private network)

# Optional:
# ACE_MODEL=claude-opus-4-8         # override Ace's model (defaults to the live bot's model)
# ACE_MAX_TOKENS=900                # response token budget (matches bot.py)
# CORS_ORIGINS=https://ace-portal.up.railway.app   # comma-separated; defaults to *
# PORTAL_TOKEN_SECRET=              # optional explicit signing secret for session tokens

# Railway sets PORT automatically.
